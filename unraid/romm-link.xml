<?xml version="1.0" encoding="utf-8"?>
<Container version="2">
  <Name>romm-link</Name>
  <Repository>ghcr.io/aedankerr/romm-link:dev</Repository>
  <Registry>https://github.com/Aedankerr/romm-link/pkgs/container/romm-link</Registry>
  <Network>romm</Network>
  <MyIP/>
  <Shell>sh</Shell>
  <Privileged>false</Privileged>
  <Support>https://github.com/Aedankerr/romm-link/issues</Support>
  <Project>https://github.com/Aedankerr/romm-link</Project>
  <Overview>Unraid-first companion launcher for RomM. Discovers RomM and emulator containers on the Docker network, then exposes a browser health/discovery dashboard.</Overview>
  <Category>GameServers: MediaApp:Other</Category>
  <WebUI>http://[IP]:[PORT:8766]/</WebUI>
  <TemplateURL>https://raw.githubusercontent.com/Aedankerr/romm-link/dev/unraid/romm-link.xml</TemplateURL>
  <Icon></Icon>
  <ExtraParams/>
  <PostArgs/>
  <CPUset/>
  <DateInstalled/>
  <DonateText/>
  <DonateLink/>
  <Requires>Existing Docker network named romm and access to /var/run/docker.sock.</Requires>
  <Config Name="Web UI Port" Target="8766" Default="8766" Mode="tcp" Description="romm-link dashboard/API port" Type="Port" Display="always" Required="true" Mask="false">8766</Config>
  <Config Name="Docker Socket" Target="/var/run/docker.sock" Default="/var/run/docker.sock" Mode="rw" Description="Allows romm-link to discover RomM/emulator containers and their status" Type="Path" Display="always" Required="true" Mask="false">/var/run/docker.sock</Config>
  <Config Name="RomM URL" Target="ROMM_URL" Default="http://romm:8080" Description="RomM API base URL. Use Docker DNS on the romm network; do not use fixed IP addresses." Type="Variable" Display="always" Required="true" Mask="false">http://romm:8080</Config>
  <Config Name="RomM API Key" Target="ROMM_API_KEY" Default="" Description="Optional RomM API key for authenticated API calls" Type="Variable" Display="advanced" Required="false" Mask="true"></Config>
  <Config Name="Docker Network" Target="DOCKER_NETWORK" Default="romm" Description="Existing Docker network shared by RomM and emulator containers" Type="Variable" Display="always" Required="true" Mask="false">romm</Config>
  <Config Name="PCSX2 Container" Target="PCSX2_CONTAINER" Default="pcsx2" Description="PCSX2 container name" Type="Variable" Display="advanced" Required="true" Mask="false">pcsx2</Config>
  <Config Name="RPCS3 Container" Target="RPCS3_CONTAINER" Default="rpcs3" Description="RPCS3 container name" Type="Variable" Display="advanced" Required="true" Mask="false">rpcs3</Config>
  <Config Name="Dolphin Container" Target="DOLPHIN_CONTAINER" Default="dolphin" Description="Dolphin container name" Type="Variable" Display="advanced" Required="true" Mask="false">dolphin</Config>
  <Config Name="PCSX2 Web URL" Target="PCSX2_WEB_URL" Default="http://pcsx2:3000" Description="Browser endpoint for PCSX2 via Docker DNS" Type="Variable" Display="advanced" Required="true" Mask="false">http://pcsx2:3000</Config>
  <Config Name="RPCS3 Web URL" Target="RPCS3_WEB_URL" Default="http://rpcs3:3000" Description="Browser endpoint for RPCS3 via Docker DNS" Type="Variable" Display="advanced" Required="true" Mask="false">http://rpcs3:3000</Config>
  <Config Name="Dolphin Web URL" Target="DOLPHIN_WEB_URL" Default="http://dolphin:3000" Description="Browser endpoint for Dolphin via Docker DNS" Type="Variable" Display="advanced" Required="true" Mask="false">http://dolphin:3000</Config>
</Container>
