<?xml version="1.0"?>
<Container version="2">
  <Name>romm-link</Name>
  <Repository>aedankerr/romm-link:latest</Repository>
  <Registry>https://hub.docker.com/r/aedankerr/romm-link</Registry>
  <Network>bridge</Network>
  <Shell>sh</Shell>
  <Privileged>false</Privileged>
  <Support>https://github.com/Aedankerr/romm-link/issues</Support>
  <Project>https://github.com/Aedankerr/romm-link</Project>
  <Overview>romm-link connects RomM to browser-accessible emulator containers such as PCSX2, RPCS3 and Dolphin.</Overview>
  <Category>GameServers: Tools:</Category>
  <WebUI>http://[IP]:[PORT:8787]/</WebUI>
  <Icon>https://raw.githubusercontent.com/Aedankerr/romm-link/main/docs/icon.png</Icon>
  <Config Name="WebUI Port" Target="8787" Default="8787" Mode="tcp" Description="romm-link web UI port" Type="Port" Display="always" Required="true" Mask="false">8787</Config>
  <Config Name="Docker Socket" Target="/var/run/docker.sock" Default="/var/run/docker.sock" Mode="rw" Description="Required to start and stop emulator containers" Type="Path" Display="always" Required="true" Mask="false">/var/run/docker.sock</Config>
  <Config Name="ROMM_URL" Target="ROMM_URL" Default="http://romm:8080" Description="RomM base URL" Type="Variable" Display="always" Required="true" Mask="false">http://romm:8080</Config>
  <Config Name="ROMM_API_KEY" Target="ROMM_API_KEY" Default="" Description="RomM API key if required" Type="Variable" Display="always" Required="false" Mask="true"></Config>
</Container>
